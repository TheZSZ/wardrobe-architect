[flake8]
max-line-length = 100
exclude =
    .git,
    __pycache__,
    venv,
    .venv,
    htmlcov
# E203: whitespace before ':' (conflicts with black)
# W503: line break before binary operator
extend-ignore = E203, W503

# Per-file ignores for long lines in sample data and complex comprehensions
per-file-ignores =
    app/services/sheets.py:E501
    app/services/storage.py:E501
